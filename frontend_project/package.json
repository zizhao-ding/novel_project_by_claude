{
  "name": "front_project",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{vue,ts,js,css,scss}\"",
    "format:check": "prettier --check \"src/**/*.{vue,ts,js,css,scss}\"",
    "lint": "eslint src --fix",
    "lint:check": "eslint src",
